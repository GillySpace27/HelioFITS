<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The FITS type is EXPORTED by the containing app (see the app's
         Info.plist). The extension only references it here. -->
    <key>NSExtension</key>
    <dict>
        <key>NSExtensionAttributes</key>
        <dict>
            <!-- VIEW-BASED preview (no QLIsDataBasedPreview). A data reply is
                 routed through an Apple display bundle picked by content type,
                 and Finder's COLUMN pane REFUSES the HTML one (qldisplay.Web2)
                 — it falls back to a generic thumbnail. A view controller is
                 hosted by qldisplay.Extensions instead, which the column pane
                 does accept, so one implementation renders in the column pane,
                 gallery and the Space panel alike. -->
            <key>QLSupportedContentTypes</key>
            <array>
                <string>gov.nasa.gsfc.fits</string>
            </array>
            <key>QLSupportsSearchableItems</key>
            <false/>
        </dict>
        <key>NSExtensionPointIdentifier</key>
        <string>com.apple.quicklook.preview</string>
        <key>NSExtensionPrincipalClass</key>
        <string>$(PRODUCT_MODULE_NAME).PreviewViewController</string>
    </dict>
</dict>
</plist>
